# Copy to deploy.env in the repo root (optional — defaults work with ~/.ssh/config).
# deploy.env is gitignored — never commit secrets.

# SSH config Host alias (same as: ssh mydevclub)
DEPLOY_SSH_HOST=mydevclub

# Public hostname (nginx server_name, certbot, OAuth redirect, FRONTEND_ORIGIN)
DEPLOY_DOMAIN=classgrid.devclub.in

# Optional overrides (defaults shown)
# API_PORT=4500
# REMOTE_WEB_DIR=/var/www/classgrid
# REMOTE_API_DIR=/opt/classgrid-api
# APK_SRC=dist/app/classgrid.apk

# Legacy explicit SSH (only if you do not use ~/.ssh/config Host aliases):
# DEPLOY_HOST=203.0.113.10
# DEPLOY_USER=azureuser
# SSH_IDENTITY=$HOME/.ssh/id_ed25519

# Deprecated aliases (still supported):
# AZURE_HOST= AZURE_USER= AZURE_KEY= DOMAIN=
