# Copy to deploy.env in the repo root and fill in for ./deploy.sh
# deploy.env is gitignored — never commit real hostnames or key paths.

DEPLOY_HOST=
DEPLOY_USER=
SSH_IDENTITY=

# Public hostname (nginx server_name, certbot, OAuth redirect, FRONTEND_ORIGIN)
DEPLOY_DOMAIN=

# Optional overrides (defaults shown)
# API_PORT=4500
# REMOTE_WEB_DIR=/var/www/classgrid
# REMOTE_API_DIR=/opt/classgrid-api
# STUDENT_DATA_SRC=/path/to/studentCourses.json
# CATALOG_DATA_SRC=/path/to/courses.json

# Deprecated aliases (still supported if you already use them):
# AZURE_HOST= AZURE_USER= AZURE_KEY= DOMAIN=
