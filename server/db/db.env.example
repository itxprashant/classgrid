# Postgres for ClassGrid (calendar events, future server persistence).
# Copy to /etc/classgrid/db.env on the VM — never commit real passwords.

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=classgrid
POSTGRES_USER=classgrid
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Optional: wire into classgrid-api later
# DATABASE_URL=postgresql://classgrid:PASSWORD@127.0.0.1:5432/classgrid
