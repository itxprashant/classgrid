# ClassGrid backend env. Copy to server/.env and fill in real values.
# The .env file is gitignored.

# --- OIDC client (register at https://auth.devclub.in) ---
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Must EXACTLY match a redirect URI registered for this client.
# Local dev: http://localhost:4000/auth/callback (or http://localhost:3000/auth/callback if you proxy)
# Prod:      https://classgrid.devclub.in/auth/callback
OIDC_REDIRECT_URI=http://localhost:4000/auth/callback

# Discovery document. Default works for IITD auth.devclub.in.
OIDC_DISCOVERY_URL=https://auth.devclub.in/api/oauth/.well-known/openid-configuration

# Space-separated scopes. 'kerberos' yields the user's Kerberos id.
OIDC_SCOPE=openid profile email kerberos hostel

# --- Session ---
# Long random string; rotating it invalidates all sessions.
SESSION_SECRET=change-me-to-a-long-random-string

# Where to redirect after a successful login (the SPA).
# Local dev: http://localhost:3000
# Prod:      https://classgrid.devclub.in
FRONTEND_ORIGIN=http://localhost:3000

# Deep link scheme for the Flutter app after OAuth (?app=1 on /auth/login).
# MOBILE_APP_SCHEME=classgrid

# --- Admin (web /admin panel) ---
# Comma-separated kerberos ids allowed to use /api/admin/*
ADMIN_KERBERSES=mt6240685

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Postgres (required for semester data + user persistence) ---
# Semester catalog, enrollments, rosters, academic calendar, extra-occupied
# overlay, and Android release config are served from Postgres (migration 008).
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=classgrid
# POSTGRES_USER=classgrid
# POSTGRES_PASSWORD=
# DATABASE_URL=postgresql://classgrid:PASSWORD@127.0.0.1:5432/classgrid

# Local seed (after migrate): node scripts/db/seed_from_files.js
# Semester refresh: scripts/db/refresh_semester.sh

# --- FCM broadcast (optional; admin push from /admin/push) ---
# Path to Firebase Admin SDK service account JSON (never commit this file).
# See docs/FCM_SETUP.md for Firebase Console + prod deploy steps.
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
